    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
